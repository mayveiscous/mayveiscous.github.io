---
const { title = "Portfolio" } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>

  <body>
    <slot />
  </body>
</html>

<style>
  :root {
    --bg: #0f1117;
    --text: #e6e6e6;
    --muted: #9ca3af;
  }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    font-family: Inter, system-ui, sans-serif;
  }

  * {
    box-sizing: border-box;
  }
</style>