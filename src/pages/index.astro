---
import ProjectCard from "../components/ProjectCard.astro";

const projects = [
  {
    title: "TPU",
    description:
      "An 8-bit fantasy CPU and assembler written in Go with custom bytecode, stack operations, and compact instruction encoding.",
    tech: ["Go", "Assembler", "Virtual Machine"],
    github: "https://github.com/mayveiscous/TPU",
  },
  {
     title: "Tunascript",
      description:
     "A Lua-inspired, embeddable scripting language with a custom lexer, Pratt parser, and interpreter runtime.",
       tech: ["Go", "Pratt Parsing", "Interpreter"],
       github: "https://github.com/mayveiscous/tunascript"
  },
];
---

<style>
  .card {
    background: #171923;
    border: 1px solid #2a2f3a;
    border-radius: 16px;
    padding: 1.5rem;
    transition: transform 0.15s ease, border-color 0.15s ease;
  }

  .card:hover {
    transform: translateY(-4px);
    border-color: #7dd3fc;
  }

  .card h2 {
    margin-top: 0;
    margin-bottom: 0.75rem;
    color: #e6e6e6;
  }

  .card p {
    color: #9ca3af;
    line-height: 1.6;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .tag {
    background: #222733;
    border: 1px solid #2a2f3a;
    border-radius: 999px;
    padding: 0.35rem 0.75rem;
    font-size: 0.85rem;
    color: #e6e6e6;
  }

  .links {
    margin-top: 1.5rem;
  }

  .links a {
    color: #7dd3fc;
    text-decoration: none;
    font-weight: 600;
  }

  .links a:hover {
    text-decoration: underline;
  }
</style>

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Portfolio</title>

    <style>
      :root {
        --bg: #0f1117;
        --text: #e6e6e6;
        --muted: #9ca3af;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family: Inter, system-ui, sans-serif;
      }

      main {
        max-width: 1000px;
        margin: 0 auto;
        padding: 4rem 1.5rem;
      }

      h1 {
        font-size: 3rem;
        margin-bottom: 0.5rem;
      }

      .subtitle {
        color: var(--muted);
        margin-bottom: 3rem;
      }

      .grid {
        display: grid;
        flex-direction: column;
        gap: 1.5rem;
      }
    </style>
  </head>

  <body>
    <main>
      <h1>Mayve</h1>

      <p class="subtitle">
        Systems programming, emulators, game development, and low-level tools.
      </p>

      <section class="grid">
        {
          projects.map((project) => (
            <ProjectCard
              title={project.title}
              description={project.description}
              tech={project.tech}
              github={project.github}
            />
          ))
        }
      </section>
    </main>
  </body>
</html>

