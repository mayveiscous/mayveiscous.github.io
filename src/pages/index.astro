---
import Divider from "../components/Divider.astro";
import LanguageBadge from "../components/LanguageBadge.astro";
import ProjectCard from "../components/ProjectCard.astro";

const languages = [
  { name: "Go",     years: "3 yrs", focus: "compilers, VMs, CLI tooling" },
  { name: "Lua",    years: "5 yrs", focus: "game development, scripting"  },
  { name: "C/C++",  years: "4 yrs", focus: "systems, emulators, graphics" },
];

const projects = [
  {
    title: "TPU",
    description: "An 8-bit fantasy CPU and assembler written in Go with custom bytecode, stack operations, and compact instruction encoding.",
    tech: ["Go", "Assembler", "Virtual Machine"],
    github: "https://github.com/mayveiscous/TPU",
    image: undefined,
  },
  {
    title: "Tunascript",
    description: "A Lua-inspired, embeddable scripting language with a custom lexer, Pratt parser, and interpreter runtime.",
    tech: ["Go", "Pratt Parsing", "Interpreter"],
    github: "https://github.com/mayveiscous/tunascript",
    image: undefined,
  },
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Mayve — Portfolio</title>
    <style>
      :root {
        --bg: #0f1117;
        --text: #e6e6e6;
        --muted: #9ca3af;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family: Inter, system-ui, sans-serif;
      }
      main {
        max-width: 1600px;   /* was 1100px */
        padding: 4rem 4rem;  /* was 3.5rem 2rem — more horizontal breathing room */
        grid-template-columns: 320px 1px 1fr;  /* was 260px — slightly wider left col */
        gap: 0 3rem;         /* was 0 2rem */
      }
      .left {
        position: sticky;
        top: 3.5rem;
      }
      h1 {
        font-size: 2rem;
        margin: 0 0 0.35rem;
      }
      .subtitle {
        color: var(--muted);
        font-size: 0.875rem;
        line-height: 1.6;
        margin: 0;
      }
      .about {
        color: var(--muted);
        font-size: 0.85rem;
        line-height: 1.7;
        margin: 0;
      }
      .section-label {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #4b5563;
        margin: 0 0 0.65rem;
      }
      .badges {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }
      .right {
        min-width: 0;
      }
      .projects-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.25rem;
      }
      @media (max-width: 700px) {
        main {
          grid-template-columns: 1fr;
          padding: 2rem 1.25rem;
        }
        .left { position: static; }
        .projects-grid { grid-template-columns: 1fr; }
      }
    </style>
  </head>
  <body>
    <main>
      <aside class="left">
        <h1>Mayve</h1>
        <p class="subtitle">Systems programming, emulators,<br />game development, and low-level tools.</p>

        <Divider />

        <p class="about">
          I build things close to the metal — interpreters, virtual machines,
          and tools where performance and correctness matter. Currently open
          to roles in systems or game engineering.
        </p>

        <Divider />

        <p class="section-label">Languages</p>
        <div class="badges">
          {languages.map((lang) => (
            <LanguageBadge name={lang.name} years={lang.years} focus={lang.focus} />
          ))}
        </div>
      </aside>

      <Divider orientation="vertical" />

      <section class="right">
        <div class="projects-grid">
          {projects.map((p) => (
            <ProjectCard
              title={p.title}
              description={p.description}
              tech={p.tech}
              github={p.github}
              image={p.image}
            />
          ))}
        </div>
      </section>
    </main>
  </body>
</html>