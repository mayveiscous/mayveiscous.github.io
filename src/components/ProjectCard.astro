---
import Card from "./ui/Card.astro";

const { title, description, tech, github, hoverColor } = Astro.props;
---

<Card hoverColor={hoverColor}>
  <h3>{title}</h3>
  <p>{description}</p>

  <div class="tech">
    {tech.map((t) => (
      <span class="tech-badge">{t}</span>
    ))}
  </div>

  <a href={github} target="_blank" rel="noopener">
    GitHub
  </a>
</Card>

<style>
  h3 {
    margin: 0 0 0.5rem;
  }

  p {
    color: #9ca3af;
    font-size: 0.9rem;
    line-height: 1.5;
    flex: 1;
  }

  .tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 0.75rem 0;
  }

  .tech-badge {
    font-size: 0.78rem;

    padding: 0.3rem 0.7rem;
    border-radius: 999px;

    background: #1f2430;
    border: 1px solid #2a2f3a;

    color: #cbd5e1;
    white-space: nowrap;

    transition: border-color 0.15s ease, transform 0.15s ease;
  }

  .tech-badge:hover {
    border-color: var(--hover, #7dd3fc);
    transform: translateY(-1px);
  }

  a {
    color: #7dd3fc;
    text-decoration: none;
    margin-top: auto;
    display: inline-block;
  }
</style>