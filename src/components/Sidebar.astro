---
import Divider from "./Divider.astro";
import LanguageBadge from "./LanguageBadge.astro";
import Section from "./ui/Section.astro";

type Language = {
  name: string;
  years: string;
  focus: string;
  hoverColor: string;
};

const { languages } = Astro.props as {
  languages: Language[];
};
---

<aside class="left">
  <h1>Mayve</h1>

  <p class="subtitle">
    Systems programming, emulators,<br />
    game development, and low-level tools.
  </p>

  <div class="social-links">
   <a href="https://github.com/mayveiscous" aria-label="GitHub">
    <svg viewBox="0 0 24 24" fill="currentColor">
      <path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.6v-2.1c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.2-1.6-1.2-1.6-1-.7.1-.7.1-.7 1.1.1 1.7 1.1 1.7 1.1 1 1.7 2.6 1.2 3.2.9.1-.7.4-1.2.7-1.5-2.6-.3-5.3-1.3-5.3-5.8 0-1.3.5-2.4 1.2-3.2-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2.9-.3 1.9-.4 2.9-.4s2 .1 2.9.4c2.3-1.5 3.3-1.2 3.3-1.2.6 1.6.2 2.8.1 3.1.8.8 1.2 1.9 1.2 3.2 0 4.5-2.7 5.5-5.3 5.8.4.4.8 1.1.8 2.2v3.2c0 .4.2.7.8.6A10.8 10.8 0 0 0 23.5 12C23.5 5.7 18.3.5 12 .5z"/>
    </svg>
   </a>
 
   <a href="https://instagram.com/mayveiscous" aria-label="Instagram">
    <svg viewBox="0 0 24 24" fill="currentColor">
      <path d="M7 2h10a5 5 0 0 1 5 5v10a5 5 0 0 1-5 5H7a5 5 0 0 1-5-5V7a5 5 0 0 1 5-5zm10 2H7a3 3 0 0 0-3 3v10a3 3 0 0 0 3 3h10a3 3 0 0 0 3-3V7a3 3 0 0 0-3-3zm-5 4.5A4.5 4.5 0 1 1 7.5 13 4.5 4.5 0 0 1 12 8.5zm0 2A2.5 2.5 0 1 0 14.5 13 2.5 2.5 0 0 0 12 10.5zM17.8 6.2a1 1 0 1 1-1 1 1 1 0 0 1 1-1z"/>
    </svg>
   </a>
 
   <a href="mailto:wlevi882@gmail.com" aria-label="Email">
    <svg viewBox="0 0 24 24" fill="currentColor">
      <path d="M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"/>
    </svg>
   </a>
 </div>

  <Divider />

  <Section>
    <p class="about">
      I build things close to the metal — interpreters, virtual machines,
      and tools where performance and precision matter.
    </p>
  </Section>

  <Divider />

  <div class="badges">
   {languages.map((lang) => (
     <LanguageBadge {...lang} />
   ))}
 </div>
</aside>

<style>
  .left {
    position: sticky;
    top: 0;
  }

  h1 {
    font-size: 2rem;
    margin: 0 0 0.35rem;
  }

  .subtitle {
    color: #9ca3af;
    font-size: 0.875rem;
    line-height: 1.6;
    margin: 0 0 0.85rem;
  }

.social-links {
  display: flex;
  gap: 0.75rem;
  margin: 0.85rem 0;
}

.social-links a {
  display: flex;
  align-items: center;
  justify-content: center;

  width: 32px;
  height: 32px;

  color: #4b5563;
  transition: color 0.15s ease;
  text-decoration: none;
  flex: 0 0 auto;
}

.social-links a:hover {
  color: #e6e6e6;
}

  .badges {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
.social-links svg {
  width: 22px;
  height: 22px;
  display: block;
}
</style>